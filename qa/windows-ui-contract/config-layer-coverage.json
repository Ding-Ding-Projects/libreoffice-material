{
  "schema_version": 1,
  "contract": "windows-config-layer-coverage",
  "platform": "windows",
  "status": "source-declared",
  "runtime_verified": false,
  "generator": "bin/check-config-layer-coverage.py",
  "closure_registry": "qa/windows-ui-contract/ui-registry.json",
  "scope": "Cross-reference coverage instrument for the NON-.ui command-surface XML layer under */uiconfig/** -- every toolbar/popupmenu/menubar/statusbar command list, enumerated fresh from git and mapped 1:1 to the composition mechanism that renders it Material. This layer is invisible to the WIN-SYS-016 closure (ui-registry.json = 1260 .ui + 10 native); this registry is where 'no command surface unaccounted for' is proven. It edits no officecfg and no command XML; it only records and pins coverage.",
  "note": "Enumeration is `git ls-files --cached --others --exclude-standard` over */{toolbar,popupmenu,menubar,statusbar}/*.xml filtered to paths under a uiconfig/ segment (regex classifier below); test/user-template soffice.cfg fixtures are excluded because they live outside uiconfig/. The full 659-file set matches the config partition (toolbar 428, popupmenu 195, menubar 22, statusbar 14). The Material-rewrite-ledger command_surface_config block reports 646 (419/193/21/13) because it counts only the <module>/uiconfig/<app>/<cmd>/ 4-segment pattern and omits chart2's single-app chart2/uiconfig/<cmd>/ 3-segment command XMLs (the +13 delta: 9 toolbar, 2 popupmenu, 1 menubar, 1 statusbar). This instrument includes them so no command XML under uiconfig is unregistered. Source evidence only: runtime_verified is false; no build, pixels, or runtime interaction claimed.",
  "glob": {
    "roots": "*/uiconfig/**",
    "git_pathspecs": [
      "*/toolbar/*.xml",
      "*/popupmenu/*.xml",
      "*/menubar/*.xml",
      "*/statusbar/*.xml"
    ],
    "classifier": "(?:^|/)uiconfig/(?:[^/]+/)*(toolbar|popupmenu|menubar|statusbar)/[^/]+\\.xml$",
    "families": [
      "toolbar",
      "popupmenu",
      "menubar",
      "statusbar"
    ]
  },
  "mechanisms": {
    "menu-composition": {
      "applies_to": [
        "menubar",
        "popupmenu"
      ],
      "kind": "blanket-chrome-part",
      "contract": "qa/windows-ui-contract/menu-composition.json",
      "checker": "bin/check-windows-menu-composition.py",
      "inventory": [
        "WIN-NAV-001",
        "WIN-NAV-002"
      ],
      "note": "The Material appearance of every menubar and context (popup) menu comes from the pinned Material menubar/menupopup part-states in vcl menu code + definition.xml (guard VCL_FILE_WIDGET_THEME), not from any per-file XML edit. The command XMLs stay byte-compatible command trees, so the whole family is satisfied at the chrome level."
    },
    "statusbar-composition": {
      "applies_to": [
        "statusbar"
      ],
      "kind": "blanket-chrome-part",
      "contract": "qa/windows-ui-contract/statusbar-composition.json",
      "checker": "bin/check-windows-statusbar-composition.py",
      "inventory": [
        "WIN-NAV-008"
      ],
      "note": "The Material 28px status band is composed in vcl/source/window/status.cxx against definition.xml (guard VCL_FILE_WIDGET_THEME). Every statusbar XML lists fields rendered by that pinned band, so the family is satisfied at the chrome level."
    },
    "toolbar-button-part": {
      "applies_to": [
        "toolbar"
      ],
      "kind": "per-file-composition",
      "contracts": [
        {
          "name": "calc-chrome",
          "contract": "qa/windows-ui-contract/calc-chrome.json",
          "checker": "bin/check-calc-chrome-contract.py"
        },
        {
          "name": "writer-chrome",
          "contract": "qa/windows-ui-contract/writer-chrome.json",
          "checker": "bin/check-writer-chrome-contract.py"
        },
        {
          "name": "chart-editor",
          "contract": "qa/windows-ui-contract/chart-editor.json",
          "checker": "bin/check-chart-editor-contract.py"
        },
        {
          "name": "writer-review-composition",
          "contract": "qa/windows-ui-contract/writer-review-composition.json",
          "checker": "bin/check-windows-writer-review-composition.py"
        }
      ],
      "note": "Classic toolbars have NO blanket Material toolbar composition: the Material command surface for these commands is the notebookbar (23 .ui, inside the closure), and classic toolbars are the retained legacy alt-mode, deliberately NOT M-gated (command-overflow.json). A toolbar XML is 'satisfied' only where a chrome contract pins its per-file command composition (identity+order+visibility) and grounds it in the shared native toolbar Button/Entire part in definition.xml; all other toolbars are 'pending' notebookbar supersession -- a policy decision in officecfg, not a per-file rewrite. Honest split, not a gap the M gate can close per-file."
    }
  },
