<?xml version="1.0" encoding="UTF-8"?>
<!-- This file is part of the LibreOffice project. -->
<!-- Shared Material destructive-confirmation dialog (docs/design/08-dialogs.md 8.1). -->
<!-- Footer order Help | spacer | secondary (safe) | primary (destructive); the primary -->
<!-- carries the destructive-action role (Material @error-container). The safe action is -->
<!-- the Cancel response, and the driving helper binds it as both initial focus and the -->
<!-- Enter default so keyboard activation can never destroy data. -->
<interface domain="sfx">
  <requires lib="gtk+" version="3.24"/>
  <object class="GtkMessageDialog" id="MaterialDestructiveConfirmDialog">
    <property name="can-focus">False</property>
    <property name="title" translatable="yes" context="materialdestructiveconfirmdialog|MaterialDestructiveConfirmDialog">Confirm</property>
    <property name="resizable">False</property>
    <property name="modal">True</property>
    <property name="type-hint">dialog</property>
    <property name="skip-taskbar-hint">True</property>
    <property name="message-type">warning</property>
    <property name="text" translatable="yes" context="materialdestructiveconfirmdialog|MaterialDestructiveConfirmDialog">Do you want to continue?</property>
    <property name="secondary-text" translatable="yes" context="materialdestructiveconfirmdialog|MaterialDestructiveConfirmDialog">This action cannot be undone.</property>
    <child internal-child="vbox">
      <object class="GtkBox" id="messagedialog-vbox">
        <property name="can-focus">False</property>
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <child internal-child="action_area">
          <object class="GtkButtonBox" id="messagedialog-action_area">
            <property name="can-focus">False</property>
            <property name="layout-style">end</property>
            <child>
              <object class="GtkButton" id="safe">
                <property name="label" translatable="yes" context="stock">_Cancel</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="can-default">True</property>
                <property name="has-default">True</property>
                <property name="receives-default">True</property>
                <property name="use-underline">True</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">0</property>
              </packing>
            </child>
            <child>
              <object class="GtkButton" id="destructive">
                <property name="label" translatable="yes" context="materialdestructiveconfirmdialog|destructive">_Delete</property>
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <property name="receives-default">True</property>
                <property name="use-underline">True</property>
                <style>
                  <class name="destructive-action"/>
                </style>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">1</property>
              </packing>
            </child>
            <child>
              <object class="GtkButton" id="help">
                <property name="label" translatable="yes" context="stock">_Help</property>
                <property name="visible">False</property>
                <property name="can-focus">True</property>
                <property name="receives-default">True</property>
                <property name="use-underline">True</property>
              </object>
              <packing>
                <property name="expand">False</property>
                <property name="fill">True</property>
                <property name="position">2</property>
                <property name="secondary">True</property>
              </packing>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
            <property name="pack-type">end</property>
            <property name="position">0</property>
          </packing>
        </child>
      </object>
    </child>
    <action-widgets>
      <action-widget response="-11">help</action-widget>
      <action-widget response="-6">safe</action-widget>
      <action-widget response="-5">destructive</action-widget>
    </action-widgets>
  </object>
</interface>
